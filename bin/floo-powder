#!/usr/bin/env bash
# Built & run in production by the Agents Deployed team — https://agents-deployed.com
# floo-powder — operator CLI. Connect to a client box that has an OPEN support session,
# for a read-only audit or a push upgrade. the operator runs `connect` (and confirms the pairing
# code); after that, plain `ssh <botname>` / `rsync <botname>:` work, and the bot can run
# `floo-powder exec <botname> < script` for the read-only audit.
#
#   floo-powder [--relay H --pin FP] …  point at a relay you may not own (default: saved/local)
#   floo-powder ca-init                 one-time: create the operator CA + relay key, wire ~/.ssh
#   floo-powder invite                  print the client one-liner to hand off (uses the version tag)
#   floo-powder list                    show client boxes with an open session
#   floo-powder connect <code>          resolve the code -> the session, mint a 60-min cert, open a shell
#       [--confirm CODE]                   supply the code non-interactively (when already verified)
#       [--no-shell]                       just establish the session (then use ssh/rsync/exec)
#   floo-powder exec <handle>           run stdin on the box non-interactively (the bot/audit path)
#   floo-powder close <handle>          tear down operator-side routing for a box
#   floo-powder gc                      drop routing for sessions that are no longer live
#   floo-powder relay-install           stand up / refresh the relay from ~/.config/floo keys (reuses host key → same pin)
set -euo pipefail

FLOO_HOME="${FLOO_HOME:-$HOME/.config/floo}"
FLOO_VERSION="0.5.0"
# FLOO_POWDER_SELF_MARKER — `install` greps for this token to tell an on-disk copy of this script
# (symlink it) from being run piped via `curl … | bash` (no file to link → self-fetch the pinned tag).
FLOO_POWDER_URL="${FLOO_POWDER_URL:-https://raw.githubusercontent.com/interkelstar/floo/v$FLOO_VERSION/bin/floo-powder}"
CA="$FLOO_HOME/ca/operator_ca"
RELAY_KEY="$FLOO_HOME/relay_id_ed25519"      # operator's CLIENT key, to auth to the gw account
RELAY_HOSTKEY="$FLOO_HOME/relay_hostkey"     # the relay's HOST key (pinned; deployed by install-relay.sh)
SSH_DROPIN_DIR="$HOME/.ssh/floo.d"
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"; SD="$(cd "$(dirname "$SELF")" && pwd)"
[ -f "$FLOO_HOME/relay.env" ] && . "$FLOO_HOME/relay.env"
RELAY_HOST="${FLOO_RELAY_HOST:-${RELAY_HOST:-}}"        # set by relay.env (written by init) or FLOO_RELAY_HOST
RELAY_PORT="${FLOO_RELAY_PORT:-${RELAY_PORT:-443}}"
RELAY_USER="${FLOO_RELAY_USER:-${RELAY_USER:-gw}}"

if [ -t 1 ]; then B=$'\e[1m'; D=$'\e[2m'; G=$'\e[32m'; Y=$'\e[33m'; R=$'\e[31m'; X=$'\e[0m'; else B="" D="" G="" Y="" R="" X=""; fi
die() { printf '%serror:%s %s\n' "$R" "$X" "$*" >&2; exit 1; }
valid_handle() { [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,62}$ ]] || die "bad session handle: $1"; }
codehash() { printf '%s' "$1" | sha256sum | cut -c1-64; }

ensure_ssh_wiring() {
  mkdir -p "$SSH_DROPIN_DIR" "$HOME/.ssh"; chmod 700 "$SSH_DROPIN_DIR" "$HOME/.ssh"
  local inc="Include $SSH_DROPIN_DIR/*.conf"
  if [ ! -f "$HOME/.ssh/config" ] || ! grep -qF "$inc" "$HOME/.ssh/config"; then
    { echo "$inc"; echo; cat "$HOME/.ssh/config" 2>/dev/null || true; } > "$HOME/.ssh/config.tmp"
    mv "$HOME/.ssh/config.tmp" "$HOME/.ssh/config"; chmod 600 "$HOME/.ssh/config"
  fi
}

relay_ssh() {
  ssh -p "$RELAY_PORT" -i "$RELAY_KEY" -o IdentitiesOnly=yes \
      -o BatchMode=yes -o ConnectTimeout=12 \
      -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile="$FLOO_HOME/relay_known_hosts" \
      "$RELAY_USER@$RELAY_HOST" "$@"
}

cmd_ca_init() {
  mkdir -p "$FLOO_HOME/ca" "$FLOO_HOME/sessions" "$SSH_DROPIN_DIR"
  chmod 700 "$FLOO_HOME" "$FLOO_HOME/ca" "$SSH_DROPIN_DIR"
  [ -f "$CA" ]        || { ssh-keygen -t ed25519 -f "$CA" -N '' -q -C floo-powder-operator-ca; echo "created operator CA"; }
  [ -f "$RELAY_KEY" ] || { ssh-keygen -t ed25519 -f "$RELAY_KEY" -N '' -q -C floo-powder-operator-relay; echo "created relay (client-auth) key"; }
  # the relay's HOST key: install-relay.sh deploys this same key as the relay's identity, and we
  # pin its pubkey here so the operator CLI rejects a MITM'd relay (accept-new refuses a mismatch).
  [ -f "$RELAY_HOSTKEY" ] || { ssh-keygen -t ed25519 -f "$RELAY_HOSTKEY" -N '' -q -C floo-powder-relay-host; echo "created relay HOST key"; }
  chmod 600 "$CA" "$RELAY_KEY" "$RELAY_HOSTKEY"
  local rt; if [ "$RELAY_PORT" = 22 ]; then rt="$RELAY_HOST"; else rt="[$RELAY_HOST]:$RELAY_PORT"; fi
  printf '%s %s\n' "$rt" "$(cat "$RELAY_HOSTKEY.pub")" > "$FLOO_HOME/relay_known_hosts"
  ensure_ssh_wiring
  echo "~/.ssh/config includes $SSH_DROPIN_DIR/*.conf; relay host key pinned for $rt"
  echo
  echo "${B}Embed these public keys in the public floo:${X}"
  echo "  FLOO_OPERATOR_CA = $(cat "$CA.pub")"
  echo "  FLOO_RELAY_HOSTKEY   = $(cat "$RELAY_HOSTKEY.pub")"
}

cmd_list() {
  local out; out="$(relay_ssh list || true)"
  [ -n "$out" ] || { echo "no open support sessions."; return 0; }
  printf '%s%-20s %-8s %-18s %s%s\n' "$B" "LABEL" "SOCKET" "SID" "REGISTERED" "$X"
  while IFS=$'\t' read -r sid sock label reg; do
    printf '%-20s %-8s %-18s %s\n' "${label#label=}" "${sock#socket=}" "$sid" "${reg#registered=}"
  done <<<"$out"
}

cmd_connect() {
  local code="" shell=1
  while [ $# -gt 0 ]; do case "$1" in
    --confirm) code="$2"; shift 2;;    # pre-supply the code (scripting / tests)
    --no-shell) shell=0; shift;;
    -*) die "unknown flag $1";;
    *) code="$1"; shift;;
  esac; done
  if [ -z "$code" ]; then
    echo "${D}Ask the person you're helping to read you the pairing code on THEIR screen.${X}"
    read -r -p "Pairing code (blank to abort): " code
    [ -n "$code" ] || die "aborted."
  fi
  # resolve the code -> the session. This IS the verification: only the genuine client registered
  # that code, so a wrong code (or a squatter's different code) simply resolves to nothing.
  local meta; meta="$(relay_ssh resolve "$(codehash "${code^^}")")" \
    || die "no live session for that code — wrong code, or they closed the window."
  local sid loginuser label hostkey quick
  sid="$(sed -n 's/^sid=//p' <<<"$meta")"
  loginuser="$(sed -n 's/^loginuser=//p' <<<"$meta")"
  label="$(sed -n 's/^label=//p' <<<"$meta")"
  hostkey="$(sed -n 's/^hostkey=//p' <<<"$meta" | awk '{print $1, $2}')"
  quick="$(sed -n 's/^quick=//p' <<<"$meta")"
  { [ -n "$sid" ] && [ -n "$hostkey" ]; } || die "the relay returned an incomplete session record"
  loginuser="${loginuser:-$label}"
  echo "${G}✓ code matches — connected to the genuine session${X}"

  # friendly handle: the client's label if it's free, else the sid (both unique on this operator box)
  local handle="$sid"
  [ -n "$label" ] && [ ! -e "$SSH_DROPIN_DIR/$label.conf" ] && handle="$label"

  ensure_ssh_wiring
  local sdir="$FLOO_HOME/sessions/$handle"; rm -rf "$sdir"; mkdir -p "$sdir"; chmod 700 "$sdir"
  printf '%s %s
' "$handle" "$hostkey" > "$sdir/known_hosts"          # pin the client host key under the alias
  ssh-keygen -t ed25519 -f "$sdir/opkey" -N '' -q -C "op-$sid"
  local certline="" waitline=""
  if [ "$quick" = 1 ]; then
    # NO-CERT (quick) mode: there is no CA. Bind an ephemeral key to the session with a code-proof —
    # HMAC(code, opkey). Only the code-holder can forge it, so the client authorizes only this key.
    command -v openssl >/dev/null 2>&1 || die "quick (no-cert) mode needs openssl for the code proof"
    local opkpub authproof
    opkpub="$(cat "$sdir/opkey.pub")"
    authproof="$(printf '%s' "$opkpub" | openssl dgst -sha256 -hmac "${code^^}" | awk '{print $NF}')"
    [ -n "$authproof" ] || die "could not compute the code proof"
    relay_ssh bindop "$sid" "$authproof" "$opkpub" >/dev/null \
      || die "the relay refused the operator bind — quick mode may be off on this relay, or too many binds."
    echo "${D}no CA: bound an ephemeral key to the session by code-proof (HMAC) — TeamViewer-style${X}"
    waitline=1   # the client authorizes our key after verifying the proof; wait for it below
  else
    ssh-keygen -s "$CA" -I "op-$sid-$(date -u +%Y%m%dT%H%M%SZ)" -n "$sid" -V +60m "$sdir/opkey.pub" >/dev/null
    echo "${D}minted a 60-minute certificate (principal=$sid)${X}"
    certline="    CertificateFile \"$sdir/opkey-cert.pub\""
  fi

  cat > "$SSH_DROPIN_DIR/$handle.conf" <<CONF
# floo-powder session $handle (sid $sid) — auto-managed. Safe to delete.
Host $handle
    HostName $handle
    HostKeyAlias $handle
    User $loginuser
    ProxyCommand ssh -p "$RELAY_PORT" -i "$RELAY_KEY" -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile="$FLOO_HOME/relay_known_hosts" "$RELAY_USER@$RELAY_HOST" route "$sid"
    IdentityFile "$sdir/opkey"
$certline
    IdentitiesOnly yes
    UserKnownHostsFile "$sdir/known_hosts"
    StrictHostKeyChecking yes
    RequestTTY auto
CONF
  chmod 600 "$SSH_DROPIN_DIR/$handle.conf"

  # quick mode: the client only authorizes our key once it polls getop + verifies the HMAC. Wait briefly
  # so ssh/exec don't race the authorization (the CA path is usable the instant the cert is written).
  if [ -n "$waitline" ]; then
    local i
    for i in $(seq 1 15); do
      ssh -o BatchMode=yes -o ConnectTimeout=8 "$handle" true 2>/dev/null && break
      sleep 1
    done
  fi
  echo "${G}✓ session ready${X} — ${B}ssh $handle${X} / ${B}rsync … $handle:${X} / ${B}floo-powder exec $handle${X}"
  if [ "$shell" = 1 ]; then echo "${D}opening a shell… (their floo window shows your commands live)${X}"; exec ssh "$handle"; fi
}


cmd_exec() {
  local h="${1:-}"; [ -n "$h" ] || die "usage: floo-powder exec <handle> < script"
  valid_handle "$h"
  [ -f "$SSH_DROPIN_DIR/$h.conf" ] || die "no active session '$h' — run 'floo-powder connect <code>' first."
  # the bot/audit path: feed a script over a non-interactive shell. Recorded on the client side.
  ssh -o BatchMode=yes "$h" 'bash -s'
}

cmd_close() {
  local h="${1:-}"; [ -n "$h" ] || die "usage: floo-powder close <handle>"
  valid_handle "$h"
  rm -f "$SSH_DROPIN_DIR/$h.conf"; rm -rf "$FLOO_HOME/sessions/$h"
  echo "closed operator-side routing for '$h' (the client's Ctrl-C is the real revoke)."
}

cmd_gc() {
  local live; live="$(relay_ssh list 2>/dev/null | cut -f1 || true)"
  shopt -s nullglob
  for conf in "$SSH_DROPIN_DIR"/*.conf; do
    local bn; bn="$(basename "${conf%.conf}")"
    if ! grep -qx "$bn" <<<"$live"; then rm -f "$conf"; rm -rf "$FLOO_HOME/sessions/$bn"; echo "gc: dropped stale '$bn'"; fi
  done
  echo "gc done."
}

relay_pin() {
  local hk; hk="$(cat /etc/floo/relay_hostkey.pub 2>/dev/null || cat "$RELAY_HOSTKEY.pub" 2>/dev/null)"
  [ -n "$hk" ] || return 1
  printf '%s' "$(awk '{print $2}' <<<"$hk")" | base64 -d 2>/dev/null | sha256sum | cut -c1-16
}
print_oneliner() {
  local host="$1" port="$2" ref="${FLOO_PIN_COMMIT:-v$FLOO_VERSION}" pin relayarg
  pin="$(relay_pin)" || die "no relay host key yet — run 'floo-powder init' first."
  relayarg="$host"; [ "$port" = 443 ] || relayarg="$host:$port"
  echo "curl -fsSL https://raw.githubusercontent.com/interkelstar/floo/$ref/floo | bash -s -- --relay $relayarg --pin $pin"
}
cmd_invite() {
  local host="${FLOO_RELAY_PUBLIC_HOST:-$RELAY_HOST}" port="${FLOO_RELAY_PORT:-$RELAY_PORT}"
  [ -n "$host" ] || die "unknown relay host — run 'floo-powder init' (or set FLOO_RELAY_PUBLIC_HOST)."
  echo "${B}── give this to the person you're helping (they run it, read you the code) ──${X}"
  print_oneliner "$host" "$port"
}

# Stand up / refresh the relay daemon on THIS box from the operator keys already in ~/.config/floo
# (CA + relay HOST key — typically created by `init` or restored from backup). Reuses the host key,
# so the pin is unchanged and existing clients still verify. Idempotent (install-relay.sh is). Does
# NOT write relay.env (that's `init`'s first-time job) — a restored relay.env is left intact. This is
# the clean primitive for: a bootstrap/restore that already has the keys, run without any repo folders.
cmd_relay_install() {
  [ -f "$RELAY_HOSTKEY" ] || die "no relay host key in $FLOO_HOME — run 'floo-powder init' (first-time) or restore your keys."
  local installer="$SD/../relay/install-relay.sh" tmp=""
  if [ ! -f "$installer" ]; then            # standalone/piped: no relay/ siblings → use the embedded copy
    tmp="$(mktemp -d)"; materialize_relay "$tmp"; installer="$tmp/install-relay.sh"
  fi
  sudo "$installer" "$@" || { [ -n "$tmp" ] && rm -rf "$tmp"; die "relay install failed"; }
  [ -n "$tmp" ] && rm -rf "$tmp"
  echo "${G}✓ relay up${X}${RELAY_HOST:+ at $RELAY_HOST:$RELAY_PORT} — pin $(relay_pin 2>/dev/null || echo '?')"
}

cmd_init() {
  cmd_ca_init >/dev/null
  local host="${FLOO_RELAY_PUBLIC_HOST:-$(curl -fsS --max-time 5 ifconfig.me 2>/dev/null)}"
  local port="${FLOO_RELAY_PORT:-443}"
  [ -n "$host" ] || die "could not determine the relay's public host — set FLOO_RELAY_PUBLIC_HOST=<host>"
  if [ -z "${FLOO_INIT_NO_RELAY:-}" ]; then
    echo "standing up the relay on this box (sudo)…"
    cmd_relay_install
  fi
  # persist the public relay host so 'invite' and the operator CLI reuse it
  { grep -vE '^RELAY_(HOST|PORT)=' "$FLOO_HOME/relay.env" 2>/dev/null; echo "RELAY_HOST=$host"; echo "RELAY_PORT=$port"; } > "$FLOO_HOME/relay.env.tmp" && mv "$FLOO_HOME/relay.env.tmp" "$FLOO_HOME/relay.env"
  local ca hk; ca="$(cat "$CA.pub")"
  hk="$(cat /etc/floo/relay_hostkey.pub 2>/dev/null || cat "$RELAY_HOSTKEY.pub")"
  echo
  echo "${B}── one-time client one-liner (share this — short, paste-safe) ──${X}"
  print_oneliner "$host" "$port"
  echo
  echo "${D}(client verifies the relay via the pin, then fetches the operator key from it — nothing to paste)${X}"
  echo "${D}reprint anytime with:  floo-powder invite${X}"
  echo
  echo "${B}── or an importable config blob (for repeat support: floo config import) ──${X}"
  printf '{"name":"%s","relay_host":"%s","relay_port":"%s","operator_ca":"%s","relay_hostkey":"%s"}\n' \
    "${FLOO_OPERATOR_NAME:-$(hostname -s)}" "$host" "$port" "$ca" "$hk"
}

cmd_install() {
  local dst="${1:-$HOME/.local/bin}"; mkdir -p "$dst"
  if [ -f "$SELF" ] && grep -q FLOO_POWDER_SELF_MARKER "$SELF" 2>/dev/null; then
    ln -sf "$SELF" "$dst/floo-powder"                        # on-disk (git checkout or `curl -o`): symlink it
    local client; client="$(readlink -f "$SD/../floo" 2>/dev/null)"
    [ -n "$client" ] && [ -f "$client" ] && ln -sf "$client" "$dst/floo"
    echo "linked floo-powder${client:+ + floo} into $dst"
  else
    # piped (`curl … | bash -s -- install`): there's no file to link → fetch a pinned copy of the tag
    curl -fsSL "$FLOO_POWDER_URL" -o "$dst/floo-powder" || die "could not fetch floo-powder from $FLOO_POWDER_URL"
    chmod +x "$dst/floo-powder"
    echo "installed floo-powder $FLOO_VERSION into $dst (relay is embedded — no other files needed)"
  fi
  case ":$PATH:" in *":$dst:"*) ;; *) echo "note: add $dst to your PATH (e.g. in ~/.zshrc)";; esac
}

# materialize_relay() is defined in the EMBEDDED RELAY PAYLOAD block below — it is the verbatim,
# READABLE source of the relay (floo-route, floo-authkeys, install-relay.sh), generated from relay/
# by scripts/embed.sh. You can read exactly what `init` writes out and sudo-runs. It is defined
# before the dispatch case executes, so cmd_init / relay-extract can call it.

# verify a relay against a short pin (symmetric with the client's --pin) and save it.
verify_relay_pin() {
  local scanned blob got rt
  scanned="$(ssh-keyscan -t ed25519 -p "$RELAY_PORT" "$RELAY_HOST" 2>/dev/null)"
  blob="$(awk '{for(i=1;i<=NF;i++) if($i=="ssh-ed25519"){print $(i+1); exit}}' <<<"$scanned")"
  [ -n "$blob" ] || die "could not reach the relay at $RELAY_HOST:$RELAY_PORT to verify the pin."
  got="$(printf '%s' "$blob" | base64 -d 2>/dev/null | sha256sum | cut -c1-16)"
  [ "$got" = "$FLOO_RELAY_PIN" ] || die "relay fingerprint ($got) does not match the pin ($FLOO_RELAY_PIN) — refusing."
  mkdir -p "$FLOO_HOME"; chmod 700 "$FLOO_HOME"
  if [ "$RELAY_PORT" = 22 ]; then rt="$RELAY_HOST"; else rt="[$RELAY_HOST]:$RELAY_PORT"; fi
  printf '%s ssh-ed25519 %s\n' "$rt" "$blob" > "$FLOO_HOME/relay_known_hosts"
  { echo "RELAY_HOST=$RELAY_HOST"; echo "RELAY_PORT=$RELAY_PORT"; } > "$FLOO_HOME/relay.env"
  echo "${G}✓ relay $RELAY_HOST pinned and saved${X}"
}

# ── BEGIN EMBEDDED RELAY PAYLOAD (generated by scripts/embed.sh from relay/ — readable on purpose; DO NOT EDIT BY HAND; re-run scripts/embed.sh) ──
# The relay below is VERBATIM from relay/{floo-route,floo-authkeys,install-relay.sh} — the same code
# as in the repo. `floo-powder init` writes these out and sudo-runs install-relay.sh; read them.
materialize_relay() {
  local d="$1"; mkdir -p "$d"
  cat > "$d/floo-route" <<'FLOO_EMBED_EOF_ROUTE'
#!/usr/bin/env bash
# Built & run in production by the Agents Deployed team — https://agents-deployed.com
# floo relay dispatcher — the ForceCommand for the `gw` account.
#
# This is the ONLY thing the gw account can do. gw has no shell, no TCP forwarding, and no
# powers beyond what is dispatched here plus holding a reverse unix-socket forward. It runs
# as the unprivileged gw user. The relay is a DUMB PIVOT: `route` splices bytes between the
# operator and a client's already-encrypted SSH endpoint — it never sees session plaintext.
#
# Sessions are keyed by a random, non-secret SID. The operator never knows the SID up front —
# it `resolve`s it from the pairing code the client read aloud. So routing is by code, not name.
#
# Subcommands (taken from $SSH_ORIGINAL_COMMAND):
#   register <sid> <codehash> <loginuser> <label> <hostkey...>  client publishes a session
#   resolve <codehash>                                          operator: code -> sid + session meta
#   meta <sid> | route <sid> | deregister <sid>                 operator/client by sid
#   list                                                        enumerate sessions (label, not code)
#   opconfig                                                    serve the operator PUBLIC CA (pin-bootstrap)
set -u

SOCKDIR="${FLOO_RELAY_SOCK_DIR:-/run/floo}"
CA_FILE="${FLOO_OPERATOR_CA_FILE:-/etc/floo/operator_ca.pub}"
ALLOW_QUICK_FILE="${FLOO_ALLOW_QUICK_FILE:-/etc/floo/allow_quick}"   # marker written by install-relay.sh --allow-quick
QUICK_MAX="${FLOO_QUICK_MAX:-20}"        # cap on concurrent quick sessions
QUICK_TTL="${FLOO_QUICK_TTL:-1800}"      # quick session lifetime (seconds) before it's pruned
MAX_BINDS="${FLOO_QUICK_MAXBINDS:-64}"   # cap on stored operator binds per quick session (anti disk-fill)
allow_quick() { [ -f "$ALLOW_QUICK_FILE" ]; }
valid_authhex() { [[ "$1" =~ ^[a-f0-9]{64}$ ]]; }

log() { logger -t floo-route -- "$*" 2>/dev/null || true; }
valid_sid()      { [[ "$1" =~ ^[a-f0-9]{16}$ ]]; }                 # random routing id → can't escape SOCKDIR
valid_codehash() { [[ "$1" =~ ^[a-f0-9]{64}$ ]]; }
valid_label()    { [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,62}$ ]]; }   # display only
deny() { echo "floo: $1" >&2; log "deny: $1 (peer ${SSH_CONNECTION:-?})"; exit 1; }

# A killed tunnel leaves a STALE socket file behind (sshd's StreamLocalBindUnlink only clears
# one before the NEXT bind), so file-existence alone is misleading. Probe connectability.
# CRUCIAL: we only ever conclude DEAD on a *definitive* connection refusal (nc exit 1). Any
# ambiguous result — nc missing/errored, a signal, a hung peer — is treated as LIVE, so a
# probe failure can NEVER cause gc_dead() to delete a real, in-use session socket.
socket_live() {
  local p="$1"; [ -S "$p" ] || return 1
  command -v nc >/dev/null 2>&1 || return 0          # can't probe → assume live, never GC blindly
  timeout 2 nc -U "$p" </dev/null >/dev/null 2>&1
  case "$?" in
    0|124) return 0 ;;   # connected, or held open past the timeout → live
    1)     return 1 ;;   # connection refused → genuinely stale/dead
    *)     return 0 ;;   # ambiguous (nc error/signal) → assume live; do not delete
  esac
}
# unlink stale socket + its meta (self-heals after a power loss / SIGKILL where deregister never ran)
gc_dead() { local s="$1"; [ -e "$SOCKDIR/$s.sock" ] && ! socket_live "$SOCKDIR/$s.sock" && rm -f "$SOCKDIR/$s.sock" "$SOCKDIR/$s.meta" "$SOCKDIR/$s.binds"; return 0; }

# count quick sessions whose socket is live (the concurrency cap is on ACTIVE sessions)
count_quick_live() {
  local n=0 m s; shopt -s nullglob
  for m in "$SOCKDIR"/*.meta; do
    [ "$(sed -n 's/^quick=//p' "$m")" = 1 ] || continue
    s="$(sed -n 's/^sid=//p' "$m")"
    socket_live "$SOCKDIR/$s.sock" && n=$((n+1))
  done
  echo "$n"
}
# reap quick sessions older than the TTL (CA sessions are untouched — no quick=1/registered_epoch)
prune_quick_expired() {
  local now m e s; now="$(date +%s)"; shopt -s nullglob
  for m in "$SOCKDIR"/*.meta; do
    [ "$(sed -n 's/^quick=//p' "$m")" = 1 ] || continue
    e="$(sed -n 's/^registered_epoch=//p' "$m")"; [ -n "$e" ] || continue
    if [ $((now - e)) -gt "$QUICK_TTL" ]; then
      s="$(sed -n 's/^sid=//p' "$m")"; rm -f "$SOCKDIR/$s.sock" "$SOCKDIR/$s.meta" "$SOCKDIR/$s.binds"
    fi
  done
}

read -ra A <<<"${SSH_ORIGINAL_COMMAND:-}"
cmd="${A[0]:-}"

case "$cmd" in
  register)
    sid="${A[1]:-}";       valid_sid "$sid"           || deny "bad sid"
    ch="${A[2]:-}";        valid_codehash "$ch"       || deny "bad code hash"
    loginuser="${A[3]:-}"; [[ "$loginuser" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || deny "bad login user"
    label="${A[4]:-}";     valid_label "$label"       || deny "bad label"
    # optional quick flag at position 5 (literal "quick=0|1"); else the host key starts at 5 (back-compat
    # with v0.2 clients that send no flag — their A[5] is "ssh-ed25519 …", which is NOT "quick=*").
    quick=0
    if [[ "${A[5]:-}" == quick=* ]]; then
      quick="${A[5]#quick=}"; [[ "$quick" =~ ^[01]$ ]] || deny "bad quick flag"; hostpub="${A[*]:6}"
    else
      hostpub="${A[*]:5}"
    fi
    [ -n "$hostpub" ] || deny "missing host key"
    case "$hostpub" in ssh-ed25519\ *|ssh-rsa\ *|ecdsa-*\ *) ;; *) deny "bad host key" ;; esac
    if [ "$quick" = 1 ]; then
      allow_quick || deny "quick mode not enabled on this relay"
      prune_quick_expired
      [ "$(count_quick_live)" -lt "$QUICK_MAX" ] || deny "too many active quick sessions; try again shortly"
    fi
    umask 077; mkdir -p "$SOCKDIR" 2>/dev/null   # metas are 0600 — code hashes not world-readable
    gc_dead "$sid"
    socket_live "$SOCKDIR/$sid.sock" && deny "a live session already exists for that id"
    {
      echo "sid=$sid"
      echo "code=$ch"
      echo "loginuser=$loginuser"
      echo "label=$label"
      echo "quick=$quick"
      echo "registered=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo "registered_epoch=$(date +%s)"
      echo "peer=${SSH_CONNECTION%% *}"
      echo "hostkey=$hostpub"
    } > "$SOCKDIR/$sid.meta.tmp" && mv "$SOCKDIR/$sid.meta.tmp" "$SOCKDIR/$sid.meta"
    log "register $sid ($label)"
    echo "registered $sid"
    ;;

  resolve)
    # code -> sid. Linear-scan live metas for a matching code hash; this IS the verification
    # (only the genuine client registered that hash). Never echoes the code hash itself.
    ch="${A[1]:-}"; valid_codehash "$ch" || deny "bad code hash"
    prune_quick_expired
    shopt -s nullglob
    for m in "$SOCKDIR"/*.meta; do
      [ "$(sed -n 's/^code=//p' "$m")" = "$ch" ] || continue
      sid="$(sed -n 's/^sid=//p' "$m")"
      socket_live "$SOCKDIR/$sid.sock" || { gc_dead "$sid"; continue; }
      echo "socket=live"
      grep -vE '^(code|sid|registered_epoch)=' "$m"   # loginuser, label, quick, registered, peer, hostkey
      echo "sid=$sid"
      exit 0
    done
    deny "no live session for that code"
    ;;

  meta)
    sid="${A[1]:-}"; valid_sid "$sid" || deny "bad sid"
    [ -f "$SOCKDIR/$sid.meta" ] || deny "no such session"
    if socket_live "$SOCKDIR/$sid.sock"; then echo "socket=live"; else echo "socket=absent"; fi
    grep -vE '^(code|registered_epoch)=' "$SOCKDIR/$sid.meta"
    ;;

  route)
    sid="${A[1]:-}"; valid_sid "$sid" || deny "bad sid"
    socket_live "$SOCKDIR/$sid.sock" || { gc_dead "$sid"; deny "no live socket"; }
    log "route $sid -> ${SSH_CONNECTION%% *}"
    exec nc -U "$SOCKDIR/$sid.sock"
    ;;

  bindop)
    sid="${A[1]:-}";  valid_sid "$sid"      || deny "bad sid"
    auth="${A[2]:-}"; valid_authhex "$auth" || deny "bad auth"
    opkey="${A[*]:3}"; [ -n "$opkey" ]      || deny "missing operator key"
    case "$opkey" in ssh-ed25519\ *|ssh-rsa\ *|ecdsa-*\ *) ;; *) deny "bad operator key" ;; esac
    [ -f "$SOCKDIR/$sid.meta" ] || deny "no such session"
    [ "$(sed -n 's/^quick=//p' "$SOCKDIR/$sid.meta")" = 1 ] || deny "not a quick session"
    allow_quick || deny "quick mode not enabled on this relay"
    socket_live "$SOCKDIR/$sid.sock" || { gc_dead "$sid"; deny "no live socket"; }
    # STORE-ALL (not first-write-wins): a junk bind can't squat the slot; the code-holder's bind is
    # found by the client among the inert ones. Cap the list to bound disk use.
    n="$( [ -f "$SOCKDIR/$sid.binds" ] && wc -l < "$SOCKDIR/$sid.binds" || echo 0 )"
    [ "$n" -lt "$MAX_BINDS" ] || deny "too many bind attempts for that session"
    umask 077; printf '%s %s\n' "$auth" "$opkey" >> "$SOCKDIR/$sid.binds"
    log "bindop $sid"
    echo "bound $sid"
    ;;

  getop)
    sid="${A[1]:-}"; valid_sid "$sid" || deny "bad sid"
    [ -f "$SOCKDIR/$sid.binds" ] || deny "no operator bound yet"
    cat "$SOCKDIR/$sid.binds"
    ;;

  deregister)
    sid="${A[1]:-}"; valid_sid "$sid" || deny "bad sid"
    rm -f "$SOCKDIR/$sid.sock" "$SOCKDIR/$sid.meta" "$SOCKDIR/$sid.binds"
    log "deregister $sid"
    echo "deregistered $sid"
    ;;

  list)
    prune_quick_expired
    shopt -s nullglob
    for m in "$SOCKDIR"/*.meta; do
      sid="$(sed -n 's/^sid=//p' "$m")"
      [ -n "$sid" ] || { rm -f "$m"; continue; }   # skip/clear any pre-v0.2 (nameless) meta
      if socket_live "$SOCKDIR/$sid.sock"; then live="live"; else live="absent"; gc_dead "$sid"; [ -f "$m" ] || continue; fi
      label="$(sed -n 's/^label=//p' "$m")"; reg="$(sed -n 's/^registered=//p' "$m")"
      printf '%s\tsocket=%s\tlabel=%s\tregistered=%s\n' "$sid" "$live" "$label" "$reg"
    done
    ;;

  opconfig)
    # serve the operator's PUBLIC CA so a pin-bootstrapped client can fetch it over the
    # host-key-verified relay connection instead of pasting it on the command line. Public only.
    [ -f "$CA_FILE" ] && cat "$CA_FILE" || deny "no operator CA published on this relay"
    ;;

  *)
    deny "unknown command"
    ;;
esac
FLOO_EMBED_EOF_ROUTE
  cat > "$d/floo-authkeys" <<'FLOO_EMBED_EOF_AUTHKEYS'
#!/usr/bin/env bash
# Built & run in production by the Agents Deployed team — https://agents-deployed.com
# AuthorizedKeysCommand for the relay's `gw` account.
#
# It echoes back whatever public key the client offered, so ANY key is accepted — but with
# `restrict` (no pty, no agent/X11 forwarding, no user-rc) and only `port-forwarding`
# re-enabled. The relay sshd's `Match User gw` block further narrows that to remote
# unix-socket forwarding only and pins a ForceCommand. The net authority of a gw login is
# therefore: open a reverse socket, or run the dispatcher — nothing else.
#
# Why accept any key instead of publishing a shared one? So no private key ever lives in
# the public repo (nothing for a client to find and distrust), and each client authenticates
# with its own throwaway key. Security rests on the gw account being powerless + the pairing
# code, NOT on who holds a key to reach it.
#
# Invoked by sshd as: floo-authkeys <keytype> <keyblob-base64>
set -u
t="${1:-}"; k="${2:-}"
case "$t" in
  ssh-ed25519|ssh-rsa|ecdsa-sha2-*|sk-ssh-ed25519@openssh.com|sk-ecdsa-sha2-*) ;;
  *) exit 0 ;;   # unknown type → emit nothing → auth fails
esac
[ -n "$k" ] || exit 0
# Emit the bare key — authorization only. ALL confinement is done server-side by the relay
# sshd's `Match User gw` block (AllowTcpForwarding no, AllowStreamLocalForwarding remote,
# ForceCommand, PermitTTY no, no agent/X11/tun forwarding). We deliberately do NOT add the
# `restrict` key option here: `restrict` disables the stream-local *listen* the reverse
# tunnel needs, and `port-forwarding` does not re-grant it. The Match block is the authority.
printf '%s %s\n' "$t" "$k"
FLOO_EMBED_EOF_AUTHKEYS
  cat > "$d/install-relay.sh" <<'FLOO_EMBED_EOF_INSTALL'
#!/usr/bin/env bash
# Built & run in production by the Agents Deployed team — https://agents-deployed.com
# install-relay.sh — stand up the floo relay on the OPERATOR's box.
#
# The relay is the switchboard: a dedicated, isolated sshd instance (does NOT touch the
# box's primary sshd) listening on 443, serving only a powerless `gw` account. It maps a
# botname to a client's live reverse socket and pivots bytes between the operator and the
# client's own encrypted SSH endpoint. It never sees session plaintext.
#
# Provisions (same spirit as the operator's other personal infra, e.g. the SearXNG podman
# container): a gw user, the dispatcher + authkeys helper, a tmpfiles entry for the socket
# dir, the relay sshd config + host key, a systemd unit, and a firewall opening for 443.
#
#   sudo ./install-relay.sh                 # install/refresh (default port 443)
#   sudo FLOO_RELAY_PORT=2222 ./install-relay.sh   # alt port (testing / when 443 is taken)
#   sudo ./install-relay.sh --uninstall
set -euo pipefail

PORT="${FLOO_RELAY_PORT:-443}"
SOCKDIR="/run/floo"
ETC="/etc/floo"
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --allow-quick: opt into brokering no-cert (code-only) "quick" sessions. OFF by default — enabling it
# turns the relay into an open rendezvous broker for code-only sessions, so it's a deliberate switch.
ALLOW_QUICK=0
for a in "$@"; do [ "$a" = "--allow-quick" ] && ALLOW_QUICK=1; done

[ "$(id -u)" = 0 ] || { echo "run as root (sudo)"; exit 1; }

# ── distro abstraction (Fedora/RHEL · Debian/Ubuntu · Arch · Alpine) ──────────────────────
pkg_install() {
  if   command -v dnf     >/dev/null; then dnf install -y "$@"
  elif command -v apt-get >/dev/null; then apt-get update -qq && apt-get install -y "$@"
  elif command -v pacman  >/dev/null; then pacman -Sy --noconfirm "$@"
  elif command -v apk     >/dev/null; then apk add "$@"
  else return 1; fi
}
SSHD_BIN="$(command -v sshd || echo /usr/sbin/sshd)"
open_port() {
  if   command -v firewall-cmd >/dev/null; then firewall-cmd --permanent --add-port="$1/tcp" >/dev/null 2>&1 && firewall-cmd --reload >/dev/null 2>&1
  elif command -v ufw          >/dev/null; then ufw allow "$1/tcp" >/dev/null 2>&1
  elif command -v nft          >/dev/null; then nft add rule inet filter input tcp dport "$1" accept 2>/dev/null || true
  fi
}
close_port() {
  if   command -v firewall-cmd >/dev/null; then firewall-cmd --permanent --remove-port="$1/tcp" 2>/dev/null || true; firewall-cmd --reload >/dev/null 2>&1 || true
  elif command -v ufw          >/dev/null; then ufw delete allow "$1/tcp" >/dev/null 2>&1 || true
  fi
}
ensure_gw_user() {
  id gw >/dev/null 2>&1 && return 0
  if command -v useradd >/dev/null; then useradd --system --create-home --home-dir /var/lib/floo --shell /bin/bash gw
  else adduser -S -D -H -h /var/lib/floo -s /bin/sh gw 2>/dev/null || adduser --system --home /var/lib/floo gw 2>/dev/null; mkdir -p /var/lib/floo; fi
}
ensure_nc() {
  command -v nc >/dev/null && return 0
  if   command -v dnf     >/dev/null; then pkg_install nmap-ncat
  elif command -v apt-get >/dev/null; then pkg_install netcat-openbsd
  elif command -v pacman  >/dev/null; then pkg_install openbsd-netcat
  elif command -v apk     >/dev/null; then pkg_install netcat-openbsd
  fi
  command -v nc >/dev/null || { echo "FATAL: 'nc' (netcat) not found and could not be installed — install it and re-run; the relay needs it."; exit 1; }
}

uninstall() {
  local up; up="$(cat "$ETC/port" 2>/dev/null || echo "$PORT")"
  # complete removal — leave ZERO leftovers, so a box can be wiped/moved cleanly. The only thing
  # deliberately NOT touched is ~/.config/floo (the operator's keys = durable access).
  systemctl disable --now floo-relay.service 2>/dev/null || true
  rm -f "$ETC/allow_quick"
  rm -f /etc/systemd/system/floo-relay.service /etc/tmpfiles.d/floo.conf
  rm -f /usr/local/bin/floo-route /usr/local/bin/floo-authkeys
  rm -rf "$ETC" "$SOCKDIR"
  systemctl daemon-reload
  close_port "$up"
  rm -f /etc/fail2ban/jail.d/floo-relay.local 2>/dev/null && command -v fail2ban-client >/dev/null 2>&1 && systemctl reload fail2ban 2>/dev/null || true
  id gw >/dev/null 2>&1 && { userdel -r gw 2>/dev/null || userdel gw 2>/dev/null || true; }
  if command -v semanage >/dev/null 2>&1; then
    semanage port -d -t ssh_port_t -p tcp "$up" 2>/dev/null || true
  fi
  echo "relay fully uninstalled — service, helpers, $ETC, $SOCKDIR, the gw user, SELinux label, and the firewall"
  echo "opening are all removed. Your operator keys in ~/.config/floo are untouched."
  exit 0
}
[ "${1:-}" = "--uninstall" ] && uninstall

echo "==> gw service account"
ensure_gw_user
# useradd locks the password (!), and sshd refuses a login to a locked account ("account is
# locked") even for publickey. '*' = not locked, but no usable password (password login stays
# impossible, and PasswordAuthentication no blocks it anyway). Idempotent.
usermod -p '*' gw

echo "==> dispatcher + authkeys helper"
install -m 0755 "$SELF_DIR/floo-route"    /usr/local/bin/floo-route
install -m 0755 "$SELF_DIR/floo-authkeys" /usr/local/bin/floo-authkeys
# nc is REQUIRED: the route pivot execs it, and socket liveness is probed with it. Install it
# per-distro if absent; ensure_nc fails loudly if it still can't be provided.
ensure_nc

echo "==> socket dir ($SOCKDIR) via tmpfiles (recreated on every boot — nothing persists across reboot)"
echo "d $SOCKDIR 0755 gw gw -" > /etc/tmpfiles.d/floo.conf
systemd-tmpfiles --create /etc/tmpfiles.d/floo.conf

echo "==> relay sshd config + dedicated host key (isolated from the box's primary sshd)"
mkdir -p "$ETC"; chmod 755 "$ETC"; echo "$PORT" > "$ETC/port"
# quick (no-CA) sessions are OFF unless explicitly enabled — the relay becomes an open rendezvous
# broker for them, so it's an opt-in posture. The dispatcher checks for this marker file.
if [ "$ALLOW_QUICK" = 1 ]; then
  : > "$ETC/allow_quick"; echo "==> quick (no-cert) sessions ENABLED (--allow-quick) — relay will broker code-only sessions"
else
  rm -f "$ETC/allow_quick"; echo "==> quick (no-cert) sessions disabled (default; pass --allow-quick to enable)"
fi
# Use the operator's pre-generated relay host key (its PUBLIC half is pinned in floo as
# FLOO_RELAY_HOSTKEY) so the deployed relay's identity matches what every client verifies — this
# closes a relay-MITM. Resolve it from the invoking user's config; if absent, generate a fresh one
# and print its pubkey so floo can be updated to match.
if [ ! -f "$ETC/relay_hostkey" ]; then
  SRC="${FLOO_RELAY_HOSTKEY_SRC:-}"
  [ -z "$SRC" ] && [ -n "${SUDO_USER:-}" ] && SRC="$(getent passwd "$SUDO_USER" | cut -d: -f6)/.config/floo/relay_hostkey"
  if [ -n "$SRC" ] && [ -f "$SRC" ]; then
    install -m600 "$SRC" "$ETC/relay_hostkey"; install -m644 "$SRC.pub" "$ETC/relay_hostkey.pub" 2>/dev/null || true
    echo "   using the operator's pre-pinned relay host key ($SRC)"
  else
    ssh-keygen -t ed25519 -f "$ETC/relay_hostkey" -N '' -q -C "floo-relay-host"
    echo "   ! generated a FRESH relay host key — embed its pubkey in floo FLOO_RELAY_HOSTKEY:"
    cat "$ETC/relay_hostkey.pub"
  fi
fi
chmod 600 "$ETC/relay_hostkey"
# publish the operator's PUBLIC CA so pin-bootstrapped clients can fetch it via the relay's 'opconfig'
CA_SRC="${FLOO_OPERATOR_CA_SRC:-}"
[ -z "$CA_SRC" ] && [ -n "${SUDO_USER:-}" ] && CA_SRC="$(getent passwd "$SUDO_USER" | cut -d: -f6)/.config/floo/ca/operator_ca.pub"
if [ -n "$CA_SRC" ] && [ -f "$CA_SRC" ]; then
  install -m644 "$CA_SRC" "$ETC/operator_ca.pub"; echo "   published operator CA for pin-bootstrap (opconfig)"
else
  echo "   ! operator CA not found ($CA_SRC) — pin-bootstrap clients can't fetch it; set FLOO_OPERATOR_CA_SRC"
fi
cat > "$ETC/relay_sshd_config" <<CFG
# floo relay — isolated sshd instance. ONLY the gw account, ONLY forwarding.
Port $PORT
ListenAddress 0.0.0.0
ListenAddress ::
HostKey $ETC/relay_hostkey
PidFile /run/floo-relay.pid
LogLevel VERBOSE
# DoS hardening: cap concurrent unauthenticated handshakes (global + per source), short budgets
MaxStartups 10:50:60
PerSourceMaxStartups 4
PerSourceNetBlockSize 24
LoginGraceTime 15
MaxAuthTries 3
AllowUsers gw
PermitRootLogin no
UsePAM no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
AuthenticationMethods publickey
# accept any offered key (no shared secret to publish); the gw account is powerless anyway
AuthorizedKeysFile none
AuthorizedKeysCommand /usr/local/bin/floo-authkeys %t %k
AuthorizedKeysCommandUser nobody
X11Forwarding no
AllowAgentForwarding no
PermitTunnel no
ClientAliveInterval 30
ClientAliveCountMax 4
Match User gw
    # NOTE: 'AllowTcpForwarding no' is a master switch that ALSO disables the stream-local
    # forward we need (verified on OpenSSH 10.2). So we permit only the narrowest set:
    AllowTcpForwarding remote          # blocks -L (relay-as-jump to other hosts)
    PermitListen none                  # blocks -R TCP listeners (no opening ports on the relay)
    AllowStreamLocalForwarding remote  # allows ONLY the client's reverse unix socket
    StreamLocalBindUnlink yes
    PermitTTY no
    ForceCommand /usr/local/bin/floo-route
CFG
"$SSHD_BIN" -t -f "$ETC/relay_sshd_config" && echo "   sshd config OK"

# SELinux: under systemd the relay runs in the confined sshd_t domain, which may bind only the
# ssh port (22). Our port (443 = http_port_t by default) is refused with EACCES until we label it
# as an ssh port. Idempotent, and reverted by --uninstall, so a wiped box is left clean.
if command -v semanage >/dev/null 2>&1 && [ "$(getenforce 2>/dev/null)" != Disabled ]; then
  if ! semanage port -l 2>/dev/null | grep -qE "^ssh_port_t\b.*\b${PORT}\b"; then
    echo "==> SELinux: labeling tcp/$PORT as ssh_port_t"
    semanage port -a -t ssh_port_t -p tcp "$PORT" 2>/dev/null \
      || semanage port -m -t ssh_port_t -p tcp "$PORT" 2>/dev/null \
      || echo "   ! could not relabel tcp/$PORT — the relay may fail to bind under SELinux"
  fi
fi

echo "==> systemd unit"
cat > /etc/systemd/system/floo-relay.service <<UNIT
[Unit]
Description=floo relay (rendezvous sshd for client support sessions)
After=network-online.target
Wants=network-online.target

[Service]
ExecStartPre=/usr/bin/systemd-tmpfiles --create /etc/tmpfiles.d/floo.conf
ExecStart=$SSHD_BIN -D -e -f $ETC/relay_sshd_config
Restart=on-failure
RestartSec=3
# the dispatcher writes session metas as gw; sshd needs root to bind $PORT + privsep
[Install]
WantedBy=multi-user.target
UNIT
systemctl daemon-reload
systemctl enable --now floo-relay.service

echo "==> opening $PORT/tcp"
open_port "$PORT"

# ── DoS hardening: a fail2ban jail for the public gw endpoint (best-effort; cleanly removable) ──
if command -v fail2ban-client >/dev/null 2>&1 && [ -d /etc/fail2ban ]; then
  mkdir -p /etc/fail2ban/jail.d
  cat > /etc/fail2ban/jail.d/floo-relay.local <<JAIL
[floo-relay]
enabled      = true
port         = $PORT
filter       = sshd
backend      = systemd
journalmatch = _SYSTEMD_UNIT=floo-relay.service
maxretry     = 5
findtime     = 60
bantime      = 600
JAIL
  systemctl reload fail2ban 2>/dev/null || systemctl restart fail2ban 2>/dev/null || true
  echo "==> fail2ban jail 'floo-relay' enabled on :$PORT"
fi

echo
echo "relay up on :$PORT — host key fingerprint (clients pin this via accept-new on first dial):"
ssh-keygen -lf "$ETC/relay_hostkey.pub"
systemctl --no-pager --full status floo-relay.service | sed -n '1,4p' || true
FLOO_EMBED_EOF_INSTALL
  chmod +x "$d/floo-route" "$d/floo-authkeys" "$d/install-relay.sh"
}
# ── END EMBEDDED RELAY PAYLOAD ──

# leading --relay/--pin: point floo-powder at a relay you may not own, exactly like the client does
FLOO_RELAY_PIN="${FLOO_RELAY_PIN:-}"
while [ $# -gt 0 ]; do case "$1" in
  --relay) RELAY_HOST="${2%%:*}"; case "$2" in *:*) RELAY_PORT="${2##*:}";; esac; shift 2;;
  --pin)   FLOO_RELAY_PIN="$2"; shift 2;;
  *) break;;
esac; done
[ -n "$FLOO_RELAY_PIN" ] && verify_relay_pin

case "${1:-}" in
  install) shift; cmd_install "$@";;
  init)    shift; cmd_init "$@";;
  invite)  shift; cmd_invite "$@";;
  ca-init) shift; cmd_ca_init "$@";;
  list)    shift; cmd_list "$@";;
  connect) shift; cmd_connect "$@";;
  exec)    shift; cmd_exec "$@";;
  close)   shift; cmd_close "$@";;
  gc)      shift; cmd_gc "$@";;
  relay-install) shift; cmd_relay_install "$@";;
  relay-extract) shift; materialize_relay "${1:?usage: floo-powder relay-extract <dir>}"; echo "extracted embedded relay payload (floo-route, floo-authkeys, install-relay.sh) → $1";;
  --version) echo "floo-powder $FLOO_VERSION — by Agents Deployed · https://agents-deployed.com";;
  -h|--help|"") awk 'NR>=2 && /^#/{sub(/^# ?/,"");print} NR>=2 && !/^#/{exit}' "$0";;
  *) die "unknown command: $1";;
esac
